{
  "info": {
    "name": "Fleet Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api"
    }
  ],
  "item": [
    {
      "name": "Organizations",
      "item": [
        {
          "name": "List Organizations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/organizations"
          }
        },
        {
          "name": "Create Organization",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Transport Maroc\",\n  \"slug\": \"transport-maroc\",\n  \"plan\": \"pro\"\n}"
            },
            "url": "{{base_url}}/organizations"
          }
        },
        {
          "name": "Get Organization",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/organizations/1"
          }
        },
        {
          "name": "Update Organization",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Transport Maroc Updated\",\n  \"plan\": \"enterprise\"\n}"
            },
            "url": "{{base_url}}/organizations/1"
          }
        },
        {
          "name": "Delete Organization",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/organizations/1"
          }
        }
      ]
    },
    {
      "name": "Drivers",
      "item": [
        {
          "name": "List Drivers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/drivers"
          }
        },
        {
          "name": "List Available Drivers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/drivers?status=available",
              "query": [{ "key": "status", "value": "available" }]
            }
          }
        },
        {
          "name": "Create Driver",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Hassan Alami\",\n  \"phone\": \"0661009999\",\n  \"license_no\": \"DL-099\",\n  \"status\": \"available\"\n}"
            },
            "url": "{{base_url}}/drivers"
          }
        },
        {
          "name": "Get Driver",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/drivers/1"
          }
        },
        {
          "name": "Update Driver",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Hassan Alami\",\n  \"phone\": \"0661009999\",\n  \"license_no\": \"DL-099\",\n  \"status\": \"unavailable\"\n}"
            },
            "url": "{{base_url}}/drivers/1"
          }
        },
        {
          "name": "Delete Driver",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/drivers/1"
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "List Vehicles",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/vehicles"
          }
        },
        {
          "name": "List Available Vehicles",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/vehicles?status=available",
              "query": [{ "key": "status", "value": "available" }]
            }
          }
        },
        {
          "name": "Create Vehicle",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Iveco Daily\",\n  \"plate\": \"F-6006-GA\",\n  \"year\": \"2022\",\n  \"status\": \"available\",\n  \"mileage\": 15000\n}"
            },
            "url": "{{base_url}}/vehicles"
          }
        },
        {
          "name": "Get Vehicle",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/vehicles/1"
          }
        },
        {
          "name": "Update Vehicle",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Iveco Daily\",\n  \"plate\": \"F-6006-GA\",\n  \"year\": \"2022\",\n  \"status\": \"in_maintenance\",\n  \"mileage\": 16000\n}"
            },
            "url": "{{base_url}}/vehicles/1"
          }
        },
        {
          "name": "Delete Vehicle",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/vehicles/1"
          }
        }
      ]
    },
    {
      "name": "Trips",
      "item": [
        {
          "name": "List Trips (grouped by status)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/trips"
          }
        },
        {
          "name": "Create Trip",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup_address\": \"Tanger - Port\",\n  \"dropoff_address\": \"Tétouan - Centre\",\n  \"scheduled_at\": \"2026-04-25 08:00:00\",\n  \"duration_minutes\": 90,\n  \"priority\": \"high\",\n  \"notes\": \"Livraison urgente\"\n}"
            },
            "url": "{{base_url}}/trips"
          }
        },
        {
          "name": "Get Trip",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/trips/1"
          }
        },
        {
          "name": "Update Trip",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup_address\": \"Tanger - Nouveau Port\",\n  \"priority\": \"medium\",\n  \"duration_minutes\": 120\n}"
            },
            "url": "{{base_url}}/trips/1"
          }
        },
        {
          "name": "Delete Trip",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/trips/1"
          }
        },
        {
          "name": "Assign Driver & Vehicle",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"driver_id\": 1,\n  \"vehicle_id\": 1\n}"
            },
            "url": "{{base_url}}/trips/1/assign"
          }
        },
        {
          "name": "Update Trip Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "url": "{{base_url}}/trips/1/status"
          }
        }
      ]
    },
    {
      "name": "Edge Cases",
      "item": [
        {
          "name": "[422] Assign unavailable vehicle",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"driver_id\": 3,\n  \"vehicle_id\": 4\n}"
            },
            "url": "{{base_url}}/trips/1/assign"
          }
        },
        {
          "name": "[422] Assign driver with overlap",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"driver_id\": 1,\n  \"vehicle_id\": 3\n}"
            },
            "url": "{{base_url}}/trips/1/assign"
          }
        },
        {
          "name": "[422] Create trip in the past",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup_address\": \"Casablanca\",\n  \"dropoff_address\": \"Rabat\",\n  \"scheduled_at\": \"2020-01-01 08:00:00\",\n  \"priority\": \"low\"\n}"
            },
            "url": "{{base_url}}/trips"
          }
        },
        {
          "name": "[422] Missing required fields",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup_address\": \"Casablanca\"\n}"
            },
            "url": "{{base_url}}/trips"
          }
        },
        {
          "name": "[422] Update status of completed trip",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"invalid_status\"\n}"
            },
            "url": "{{base_url}}/trips/1/status"
          }
        }
      ]
    }
  ]
}
